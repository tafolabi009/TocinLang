// expect: 30
// A generator yields with `yield`; `for x in gen()` drives the sequence.
def squares(n: int) -> int {
    let i = 1;
    while i <= n {
        yield i * i;
        i = i + 1;
    }
}
def main() -> int {
    let total = 0;
    for s in squares(4) { total = total + s; }   // 1+4+9+16
    return total;
}
