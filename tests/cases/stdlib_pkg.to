import std.testing;
import pkg.manager;

def main() -> int {
    testBegin();
    checkEq("major", major("1.2.3"), 1);
    checkEq("minor", minor("1.2.3"), 2);
    checkEq("patch", patch("1.2.3"), 3);
    checkEq("compare lt", compareVersions("1.2.3", "1.3.0"), -1);
    checkEq("compare gt", compareVersions("2.0.0", "1.9.9"), 1);
    checkEq("compare eq", compareVersions("1.0.0", "1.0.0"), 0);
    checkEq("caret ok", satisfiesCaret("1.5.0", "1.2.3"), 1);
    checkEq("caret major bump fails", satisfiesCaret("2.0.0", "1.2.3"), 0);
    checkEq("caret below fails", satisfiesCaret("1.2.0", "1.2.3"), 0);
    checkEq("tilde ok", satisfiesTilde("1.2.9", "1.2.3"), 1);
    checkEq("tilde minor bump fails", satisfiesTilde("1.3.0", "1.2.3"), 0);
    checkEq("satisfies >=", satisfies("1.5.0", "1.2.0", 1), 1);
    checkEq("satisfies < fail", satisfies("1.5.0", "1.2.0", 6), 0);
    let cands = [makeCode(1,0,0), makeCode(1,2,0), makeCode(1,5,3), makeCode(2,0,0)];
    checkEq("bestMatch >=1.1.0", bestMatch(cands, makeCode(1,1,0), 1), makeCode(2,0,0));
    return testSummary();
}
